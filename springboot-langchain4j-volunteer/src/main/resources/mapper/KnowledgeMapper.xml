<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.application.ai.practice.mapper.KnowledgeDocMapper">

    <!-- 分页查询知识库列表 -->
    <select id="selectKnowledgePage" resultType="com.application.ai.practice.model.entity.KnowledgeDoc">
        SELECT t.* FROM knowledge_doc t
        WHERE t.deleted = 0
        <if test="query.sortField != null and query.sortField != ''">
            ORDER BY ${query.sortField}
            <if test="query.sortOrder != null and query.sortOrder != ''">
                ${query.sortOrder}
            </if>
        </if>
        <if test="query.sortField == null or query.sortField == ''">
            ORDER BY t.create_time DESC
        </if>
    </select>

    <!-- 根据标题批量删除（覆盖导入） -->
    <delete id="deleteByTitleList">
        DELETE FROM knowledge_doc
        WHERE doc_title IN
        <foreach collection="titleList" item="title" open="(" separator="," close=")">
            #{title}
        </foreach>
        AND deleted = 0
    </delete>

</mapper>